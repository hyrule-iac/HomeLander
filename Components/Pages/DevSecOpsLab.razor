@page "/devsecops-lab"

<PageTitle>DevSecOps Lab · Dark Mode</PageTitle>

<style>
    :root {
        --bg-black: #000000;
        --card-bg: #0d0d0d;
        --border-color: #262626;
        --text-primary: #ffffff;
        --text-secondary: #a0a0a0;
        --accent-blue: #0078d4;
    }

    .lab-container {
        font-family: 'Segoe UI', sans-serif;
        padding: 20px;
        color: var(--text-primary);
        background-color: var(--bg-black);
        min-height: 100vh;
        max-width: 1100px;
        margin: auto;
    }

    .hero { padding: 1.5rem 0; border-bottom: 1px solid var(--border-color); margin-bottom: 20px; }
    .hero-title { font-size: 26px; font-weight: 700; color: var(--text-primary); }
    .hero-sub { font-size: 14px; color: var(--text-secondary); margin-top: 6px; }
    
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 15px; margin-bottom: 2rem; }
    .stat { background: var(--card-bg); border-radius: 10px; padding: 1.2rem; border: 1px solid var(--border-color); transition: transform 0.2s; }
    .stat:hover { transform: translateY(-3px); border-color: var(--accent-blue); }
    .stat-val { font-size: 24px; font-weight: 700; color: var(--accent-blue); }
    .stat-lbl { font-size: 11px; color: var(--text-secondary); margin-top: 5px; text-transform: uppercase; letter-spacing: 1px; }

    .tabs { display: flex; gap: 12px; margin-bottom: 1.5rem; }
    .tab { font-size: 14px; padding: 8px 18px; border-radius: 6px; border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); cursor: pointer; transition: 0.3s; }
    .tab.active { background: var(--accent-blue); color: white; border-color: var(--accent-blue); box-shadow: 0 4px 12px rgba(0, 120, 212, 0.3); }
    .tab:hover:not(.active) { background: #1a1a1a; color: white; }

    .stage { border: 1px solid var(--border-color); border-radius: 10px; margin-bottom: 12px; background: var(--card-bg); overflow: hidden; }
    .stage-header { display: flex; align-items: center; gap: 12px; padding: 14px 18px; cursor: pointer; }
    .stage-header:hover { background: #161616; }
    
    .stage-dot { width: 10px; height: 10px; border-radius: 50%; box-shadow: 0 0 8px currentColor; }
    .dot-blue { color: #0078d4; background: #0078d4; }
    .dot-amber { color: #ffb900; background: #ffb900; }
    
    .stage-name { font-size: 15px; font-weight: 600; flex: 1; color: #f0f0f0; }
    .stage-time { font-size: 12px; color: #666; }

    .stage-body { padding: 20px; border-top: 1px solid var(--border-color); background: #050505; }
    .step { background: #0d0d0d; padding: 14px; border-radius: 8px; border: 1px solid #1f1f1f; display: flex; gap: 14px; margin-bottom: 12px; }
    .step-num { font-weight: 800; color: var(--accent-blue); font-size: 14px; }
    .step-title { font-weight: 600; font-size: 14px; color: #e0e0e0; }
    .step-desc { font-size: 13px; color: #b0b0b0; margin: 8px 0; }
    .cmd-block { background: #000; color: #00ff41; padding: 12px; border-radius: 6px; font-family: 'Consolas', monospace; font-size: 12px; border: 1px solid #1a1a1a; }
    
    .badge { font-size: 10px; padding: 3px 10px; border-radius: 4px; font-weight: 600; text-transform: uppercase; }
    .badge-tool { background: rgba(0, 120, 212, 0.1); color: #58a6ff; border: 1px solid rgba(0, 120, 212, 0.3); }
    .badge-sec { background: rgba(232, 17, 35, 0.1); color: #f85149; border: 1px solid rgba(232, 17, 35, 0.3); }
</style>

<div class="lab-container">
    <div class="hero">
        <h1 class="hero-title">Demo DevSecOps Lab</h1>
        <p class="hero-sub">Infrastructure as Code & Security Pipelines · Hybrid Cloud</p>
    </div>

    <div class="stats">
        <div class="stat"><div class="stat-val">6</div><div class="stat-lbl">Stages</div></div>
        <div class="stat"><div class="stat-val">47m</div><div class="stat-lbl">Duration</div></div>
        <div class="stat"><div class="stat-val">5</div><div class="stat-lbl">Gates</div></div>
        <div class="stat"><div class="stat-val">AZ/GH</div><div class="stat-lbl">Stack</div></div>
    </div>

    <div class="tabs">
        <button class="tab @(activeTab == "stages" ? "active" : "")" @onclick='() => SetTab("stages")'>Pipeline Stages</button>
        <button class="tab @(activeTab == "arch" ? "active" : "")" @onclick='() => SetTab("arch")'>Architecture</button>
    </div>

    @if (activeTab == "stages")
    {
        <div class="panel">
            <div class="stage">
                <div class="stage-header" @onclick='() => ToggleStage("s1")'>
                    <div class="stage-dot dot-blue"></div>
                    <div class="stage-name">Stage 1 · CI Orchestrator (GitHub Actions)</div>
                    <div class="stage-time">~5 min</div>
                </div>
                @if (IsStageOpen("s1"))
                {
                    <div class="stage-body">
                        <div class="step">
                            <div class="step-num">1.1</div>
                            <div class="step-info">
                                <div class="step-title">Environment Matrix <span class="badge badge-tool">GH Actions</span></div>
                                <div class="step-desc">Setup .NET 10 & Terraform. Orchestrating triggers across multiple cloud environments.</div>
                                <div class="cmd-block">dotnet build --configuration Release</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private string activeTab = "stages";
    private HashSet<string> openStages = new() { "s1" };
    private void SetTab(string tabId) => activeTab = tabId;
    private void ToggleStage(string id) { if (!openStages.Add(id)) openStages.Remove(id); }
    private bool IsStageOpen(string id) => openStages.Contains(id);
}