@page "/devsecops-lab"

<PageTitle>DevSecOps Lab · Full Pipeline</PageTitle>

<style>
    :root {
        --bg-black: #000000;
        --card-bg: #0d0d0d;
        --border-color: #262626;
        --text-primary: #ffffff;
        --text-secondary: #a0a0a0;
        --accent-blue: #0078d4;
        --terminal-green: #00ff41;
    }

    .lab-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
        color: var(--text-primary);
        background-color: var(--bg-black);
        min-height: 100vh;
        max-width: 1100px;
        margin: auto;
    }

    .hero { padding: 1.5rem 0; border-bottom: 1px solid var(--border-color); margin-bottom: 20px; }
    .hero-title { font-size: 26px; font-weight: 700; color: var(--text-primary); }
    .hero-sub { font-size: 14px; color: var(--text-secondary); margin-top: 6px; }
    
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 15px; margin-bottom: 2rem; }
    .stat { background: var(--card-bg); border-radius: 10px; padding: 1.2rem; border: 1px solid var(--border-color); }
    .stat-val { font-size: 24px; font-weight: 700; color: var(--accent-blue); }
    .stat-lbl { font-size: 11px; color: var(--text-secondary); margin-top: 5px; text-transform: uppercase; letter-spacing: 1px; }

    .stage { border: 1px solid var(--border-color); border-radius: 10px; margin-bottom: 12px; background: var(--card-bg); overflow: hidden; }
    .stage-header { display: flex; align-items: center; gap: 12px; padding: 14px 18px; cursor: pointer; transition: background 0.2s; }
    .stage-header:hover { background: #161616; }
    
    .stage-dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-blue { background: #0078d4; box-shadow: 0 0 8px #0078d4; }
    .dot-amber { background: #ffb900; box-shadow: 0 0 8px #ffb900; }
    .dot-teal { background: #008272; box-shadow: 0 0 8px #008272; }
    .dot-purple { background: #5c2d91; box-shadow: 0 0 8px #5c2d91; }
    .dot-green { background: #107c10; box-shadow: 0 0 8px #107c10; }
    .dot-red { background: #d83b01; box-shadow: 0 0 8px #d83b01; }
    
    .stage-name { font-size: 15px; font-weight: 600; flex: 1; color: #f0f0f0; }
    .stage-time { font-size: 12px; color: #666; }

    .stage-body { padding: 20px; border-top: 1px solid var(--border-color); background: #050505; }
    .step { background: #0d0d0d; padding: 14px; border-radius: 8px; border: 1px solid #1f1f1f; display: flex; gap: 14px; margin-bottom: 12px; }
    .step-num { font-weight: 800; color: var(--accent-blue); min-width: 25px; }
    .step-info { flex: 1; }
    .step-title { font-weight: 600; font-size: 14px; color: #e0e0e0; }
    .step-desc { font-size: 13px; color: #b0b0b0; margin: 8px 0; line-height: 1.4; }
    .cmd-block { background: #000; color: var(--terminal-green); padding: 12px; border-radius: 6px; font-family: 'Consolas', monospace; font-size: 12px; border: 1px solid #1a1a1a; overflow-x: auto; white-space: pre; }
    
    .badge { font-size: 10px; padding: 3px 10px; border-radius: 4px; font-weight: 600; text-transform: uppercase; margin-left: 8px; }
    .badge-tool { background: rgba(0, 120, 212, 0.1); color: #58a6ff; border: 1px solid rgba(0, 120, 212, 0.3); }
    .badge-sec { background: rgba(232, 17, 35, 0.1); color: #f85149; border: 1px solid rgba(232, 17, 35, 0.3); }
</style>

<div class="lab-container">
    <div class="hero">
        <h1 class="hero-title">Kleva DevSecOps Lab · Full Pipeline</h1>
        <p class="hero-sub">Hybrid Cloud Orchestration · GitHub & Azure DevOps</p>
    </div>

    <div class="stats">
        <div class="stat"><div class="stat-val">6</div><div class="stat-lbl">Total Stages</div></div>
        <div class="stat"><div class="stat-val">~47m</div><div class="stat-lbl">Total Time</div></div>
        <div class="stat"><div class="stat-val">8</div><div class="stat-lbl">Tools Scan</div></div>
        <div class="stat"><div class="stat-val">.NET 10</div><div class="stat-lbl">Runtime</div></div>
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s1")'>
            <div class="stage-dot dot-blue"></div>
            <div class="stage-name">Stage 1 · CI Orchestrator (GitHub Actions)</div>
            <div class="stage-time">5m</div>
        </div>
        @if (IsStageOpen("s1"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">1.1</div>
                    <div class="step-info">
                        <div class="step-title">Secret Scanning <span class="badge badge-sec">Security</span></div>
                        <div class="step-desc">TruffleHog scans to prevent secrets from entering the repository.</div>
                        <div class="cmd-block">- name: Secret Scan
  uses: trufflesecurity/trufflehog@main</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s2")'>
            <div class="stage-dot dot-amber"></div>
            <div class="stage-name">Stage 2 · Code & Dependency Security</div>
            <div class="stage-time">8m</div>
        </div>
        @if (IsStageOpen("s2"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">2.1</div>
                    <div class="step-info">
                        <div class="step-title">SAST with Semgrep <span class="badge badge-sec">Security</span></div>
                        <div class="step-desc">Static analysis to detect vulnerabilities in .NET 10 code.</div>
                    </div>
                </div>
                <div class="step">
                    <div class="step-num">2.2</div>
                    <div class="step-info">
                        <div class="step-title">SCA with Trivy <span class="badge badge-tool">Open Source</span></div>
                        <div class="step-desc">Vulnerability scanning for NuGet packages and base images.</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s3")'>
            <div class="stage-dot dot-teal"></div>
            <div class="stage-name">Stage 3 · Infrastructure as Code (Terraform)</div>
            <div class="stage-time">12m</div>
        </div>
        @if (IsStageOpen("s3"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">3.1</div>
                    <div class="step-info">
                        <div class="step-title">HCP Remote Apply <span class="badge badge-tool">HashiCorp</span></div>
                        <div class="step-desc">Remote execution for state persistence in Terraform Cloud.</div>
                        <div class="cmd-block">terraform apply -auto-approve</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s4")'>
            <div class="stage-dot dot-purple"></div>
            <div class="stage-name">Stage 4 · Cloud & Container Configuration</div>
            <div class="stage-time">7m</div>
        </div>
        @if (IsStageOpen("s4"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">4.1</div>
                    <div class="step-info">
                        <div class="step-title">Policy as Code <span class="badge badge-sec">Azure Policy</span></div>
                        <div class="step-desc">Audit tags and region restrictions across the newly created Azure resources.</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s5")'>
            <div class="stage-dot dot-green"></div>
            <div class="stage-name">Stage 5 · Progressive Delivery (ArgoCD)</div>
            <div class="stage-time">10m</div>
        </div>
        @if (IsStageOpen("s5"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">5.1</div>
                    <div class="step-info">
                        <div class="step-title">Blue/Green Deployment <span class="badge badge-tool">GitOps</span></div>
                        <div class="step-desc">Zero-downtime deployment using Argo Rollouts to manage traffic shifts.</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s6")'>
            <div class="stage-dot dot-red"></div>
            <div class="stage-name">Stage 6 · Observability & Feedback</div>
            <div class="stage-time">5m</div>
        </div>
        @if (IsStageOpen("s6"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">6.1</div>
                    <div class="step-info">
                        <div class="step-title">Log Aggregation <span class="badge badge-tool">Prometheus</span></div>
                        <div class="step-desc">Real-time metric collection from the hybrid cloud environment.</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private HashSet<string> openStages = new() { "s1" };

    private void ToggleStage(string id) 
    { 
        if (!openStages.Add(id)) openStages.Remove(id); 
    }

    private bool IsStageOpen(string id) => openStages.Contains(id);
}