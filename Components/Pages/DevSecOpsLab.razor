@page "/devsecops-lab"

<PageTitle>Demo DevSecOps Lab · Full Pipeline</PageTitle>

<style>
    :root {
        --bg-black: #000000;
        --card-bg: #0d0d0d;
        --border-color: #262626;
        --text-primary: #ffffff;
        --text-secondary: #a0a0a0;
        --accent-blue: #0078d4;
        --terminal-green: #00ff41;
    }

    .lab-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
        color: var(--text-primary);
        background-color: var(--bg-black);
        min-height: 100vh;
        max-width: 1100px;
        margin: auto;
    }

    .hero { padding: 1.5rem 0; border-bottom: 1px solid var(--border-color); margin-bottom: 20px; }
    .hero-title { font-size: 26px; font-weight: 700; color: var(--text-primary); }
    .hero-sub { font-size: 14px; color: var(--text-secondary); margin-top: 6px; }
    .hero-local { display: inline-block; margin-top: 10px; font-size: 12px; color: #00ff41; background: rgba(0,255,65,0.07); border: 1px solid rgba(0,255,65,0.2); border-radius: 6px; padding: 4px 12px; }

    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 15px; margin-bottom: 2rem; }
    .stat { background: var(--card-bg); border-radius: 10px; padding: 1.2rem; border: 1px solid var(--border-color); }
    .stat-val { font-size: 24px; font-weight: 700; color: var(--accent-blue); }
    .stat-lbl { font-size: 11px; color: var(--text-secondary); margin-top: 5px; text-transform: uppercase; letter-spacing: 1px; }

    .prereq-box { background: #060a06; border: 1px solid #1a3a1a; border-radius: 10px; padding: 18px 20px; margin-bottom: 1.5rem; }
    .prereq-title { font-size: 13px; font-weight: 700; color: #00ff41; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px; }
    .prereq-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; }
    .prereq-item { background: #0d0d0d; border: 1px solid #1f3a1f; border-radius: 8px; padding: 10px 14px; }
    .prereq-name { font-size: 13px; font-weight: 600; color: #e0e0e0; }
    .prereq-cmd { font-size: 11px; color: #00ff41; font-family: 'Consolas', monospace; margin-top: 4px; }
    .prereq-note { font-size: 11px; color: #666; margin-top: 3px; }

    .stage { border: 1px solid var(--border-color); border-radius: 10px; margin-bottom: 12px; background: var(--card-bg); overflow: hidden; }
    .stage-header { display: flex; align-items: center; gap: 12px; padding: 14px 18px; cursor: pointer; transition: background 0.2s; user-select: none; }
    .stage-header:hover { background: #161616; }

    .stage-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .dot-blue   { background: #0078d4; box-shadow: 0 0 8px #0078d4; }
    .dot-amber  { background: #ffb900; box-shadow: 0 0 8px #ffb900; }
    .dot-teal   { background: #008272; box-shadow: 0 0 8px #008272; }
    .dot-purple { background: #7b5ea7; box-shadow: 0 0 8px #7b5ea7; }
    .dot-green  { background: #107c10; box-shadow: 0 0 8px #107c10; }
    .dot-coral  { background: #d85a30; box-shadow: 0 0 8px #d85a30; }

    .stage-name { font-size: 15px; font-weight: 600; flex: 1; color: #f0f0f0; }
    .stage-time { font-size: 12px; color: #555; margin-right: 8px; }
    .chevron { font-size: 14px; color: #444; transition: transform 0.2s; }
    .chevron-open { transform: rotate(90deg); }

    .stage-body { padding: 20px; border-top: 1px solid var(--border-color); background: #050505; }

    .step { background: #0d0d0d; padding: 16px; border-radius: 8px; border: 1px solid #1f1f1f; display: flex; gap: 14px; margin-bottom: 14px; }
    .step:last-child { margin-bottom: 0; }
    .step-num { font-weight: 800; color: var(--accent-blue); min-width: 28px; font-size: 13px; padding-top: 1px; }
    .step-info { flex: 1; }
    .step-title { font-weight: 600; font-size: 14px; color: #e0e0e0; }
    .step-desc { font-size: 13px; color: #b0b0b0; margin: 8px 0 6px; line-height: 1.6; }
    .step-where { font-size: 12px; color: #555; margin-bottom: 8px; }
    .step-where span { color: #888; font-style: italic; }

    .cmd-block { background: #000; color: var(--terminal-green); padding: 12px 14px; border-radius: 6px; font-family: 'Consolas', monospace; font-size: 12px; border: 1px solid #1a1a1a; overflow-x: auto; white-space: pre; line-height: 1.7; margin-top: 8px; }
    .cmd-comment { color: #3a7a3a; }

    .file-block { background: #060d06; color: #c8e6c9; padding: 12px 14px; border-radius: 6px; font-family: 'Consolas', monospace; font-size: 11px; border: 1px solid #1a3a1a; overflow-x: auto; white-space: pre; line-height: 1.6; margin-top: 8px; }

    .badge { font-size: 10px; padding: 3px 10px; border-radius: 4px; font-weight: 600; text-transform: uppercase; margin-left: 8px; vertical-align: middle; }
    .badge-tool { background: rgba(0,120,212,0.1); color: #58a6ff; border: 1px solid rgba(0,120,212,0.3); }
    .badge-sec  { background: rgba(232,17,35,0.1); color: #f85149; border: 1px solid rgba(232,17,35,0.3); }
    .badge-iac  { background: rgba(0,130,114,0.1); color: #3fb950; border: 1px solid rgba(0,130,114,0.3); }
    .badge-obs  { background: rgba(255,185,0,0.1); color: #ffb900; border: 1px solid rgba(255,185,0,0.3); }
    .badge-local { background: rgba(0,255,65,0.08); color: #00ff41; border: 1px solid rgba(0,255,65,0.2); }

    .alert-local { display: flex; gap: 10px; align-items: flex-start; background: #060a06; border: 1px solid #1a3a1a; border-radius: 8px; padding: 12px 14px; margin-bottom: 12px; }
    .alert-local-icon { color: #00ff41; font-size: 14px; margin-top: 1px; flex-shrink: 0; }
    .alert-local-text { font-size: 12px; color: #8a9a8a; line-height: 1.6; }

    .step-time { font-size: 11px; color: #444; white-space: nowrap; padding-top: 2px; flex-shrink: 0; }
</style>

<div class="lab-container">

    <div class="hero">
        <h1 class="hero-title">Demo DevSecOps Lab · Full Pipeline</h1>
        <p class="hero-sub">GitHub Actions Orchestrator · Security-first · Canary Deployments · ~47 min end-to-end</p>
        <span class="hero-local">100% LOCAL · Docker Desktop + k3d · No Cloud Costs</span>
    </div>

    <div class="stats">
        <div class="stat"><div class="stat-val">6</div><div class="stat-lbl">Total Stages</div></div>
        <div class="stat"><div class="stat-val">~47m</div><div class="stat-lbl">Total Time</div></div>
        <div class="stat"><div class="stat-val">5</div><div class="stat-lbl">Security Gates</div></div>
        <div class="stat"><div class="stat-val">.NET 10</div><div class="stat-lbl">Runtime</div></div>
        <div class="stat"><div class="stat-val">k3d</div><div class="stat-lbl">Local Cluster</div></div>
        <div class="stat"><div class="stat-val">FREE</div><div class="stat-lbl">Azure Cost</div></div>
    </div>

    <div class="prereq-box">
        <div class="prereq-title">Prerequisites · Install before starting</div>
        <div class="prereq-grid">
            <div class="prereq-item">
                <div class="prereq-name">Docker Desktop</div>
                <div class="prereq-cmd">docker --version</div>
                <div class="prereq-note">Container engine. Enable Kubernetes if preferred.</div>
            </div>
            <div class="prereq-item">
                <div class="prereq-name">k3d</div>
                <div class="prereq-cmd">choco install k3d</div>
                <div class="prereq-note">Lightweight Kubernetes on Docker. Local AKS replacement.</div>
            </div>
            <div class="prereq-item">
                <div class="prereq-name">.NET 10 SDK</div>
                <div class="prereq-cmd">dotnet --version</div>
                <div class="prereq-note">Required for building and testing the demo application.</div>
            </div>
            <div class="prereq-item">
                <div class="prereq-name">Terraform CLI</div>
                <div class="prereq-cmd">choco install terraform</div>
                <div class="prereq-note">v1.9+. Will be used with HCP Terraform Cloud.</div>
            </div>
            <div class="prereq-item">
                <div class="prereq-name">kubectl</div>
                <div class="prereq-cmd">choco install kubernetes-cli</div>
                <div class="prereq-note">CLI to interact with the k3d cluster.</div>
            </div>
            <div class="prereq-item">
                <div class="prereq-name">Argo Rollouts CLI</div>
                <div class="prereq-cmd">kubectl argo rollouts version</div>
                <div class="prereq-note">Plugin to manage canary deployments.</div>
            </div>
            <div class="prereq-item">
                <div class="prereq-name">Helm</div>
                <div class="prereq-cmd">choco install kubernetes-helm</div>
                <div class="prereq-note">To install Prometheus + Grafana in the cluster.</div>
            </div>
            <div class="prereq-item">
                <div class="prereq-name">GitHub CLI (gh)</div>
                <div class="prereq-cmd">choco install gh</div>
                <div class="prereq-note">Manage repository secrets from the terminal.</div>
            </div>
        </div>
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s1")'>
            <div class="stage-dot dot-blue"></div>
            <div class="stage-name">Stage 1 · CI Orchestrator <span class="badge badge-tool">GitHub Actions</span></div>
            <div class="stage-time">~5 min</div>
            <div class="chevron @(IsStageOpen("s1") ? "chevron-open" : "")">›</div>
        </div>
        @if (IsStageOpen("s1"))
        {
            <div class="stage-body">
                <div class="alert-local">
                    <div class="alert-local-icon">*</div>
                    <div class="alert-local-text">This stage runs on GitHub. The workflow triggers on push to main or pull requests. You can test locally using <strong>act</strong>.</div>
                </div>

                <div class="step">
                    <div class="step-num">1.1</div>
                    <div class="step-info">
                        <div class="step-title">Checkout + Environment Setup <span class="badge badge-tool">GH Actions</span></div>
                        <div class="step-desc">The first job clones the repo and configures .NET 10 and Terraform on the runner.</div>
                        <div class="step-where">File: <span>.github/workflows/devsecops.yml</span></div>
                        <div class="file-block">jobs:
  orchestrator:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-dotnet@v4</div>
                    </div>
                    <div class="step-time">~1 min</div>
                </div>

                <div class="step">
                    <div class="step-num">1.2</div>
                    <div class="step-info">
                        <div class="step-title">Secret Scanning with TruffleHog <span class="badge badge-sec">Security Gate</span></div>
                        <div class="step-desc">TruffleHog scans commit history for leaked credentials. Pipeline stops if secrets are found.</div>
                        <div class="file-block">- name: Secret scanning (TruffleHog)
  uses: trufflesecurity/trufflehog@main
  with:
    base: main
    head: HEAD</div>
                    </div>
                    <div class="step-time">~1 min</div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s2")'>
            <div class="stage-dot dot-amber"></div>
            <div class="stage-name">Stage 2 · Security Scanners <span class="badge badge-sec">SAST + SCA</span></div>
            <div class="stage-time">~8 min</div>
            <div class="chevron @(IsStageOpen("s2") ? "chevron-open" : "")">›</div>
        </div>
        @if (IsStageOpen("s2"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">2.1</div>
                    <div class="step-info">
                        <div class="step-title">SAST with Semgrep <span class="badge badge-sec">Security</span></div>
                        <div class="step-desc">Analyzes source code for patterns like SQL Injection or insecure logging.</div>
                        <div class="cmd-block"><span class="cmd-comment"># Run Semgrep locally with Docker</span>
docker run --rm -v "${PWD}:/src" semgrep/semgrep semgrep --config=p/csharp</div>
                    </div>
                    <div class="step-time">~3 min</div>
                </div>

                <div class="step">
                    <div class="step-num">2.2</div>
                    <div class="step-info">
                        <div class="step-title">SCA with Trivy <span class="badge badge-sec">Security</span></div>
                        <div class="step-desc">Scans NuGet dependencies and Docker images for CVEs. Generates SBOM.</div>
                        <div class="cmd-block">docker run --rm aquasec/trivy fs /workspace</div>
                    </div>
                    <div class="step-time">~3 min</div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s3")'>
            <div class="stage-dot dot-teal"></div>
            <div class="stage-name">Stage 3 · Build & Containerize <span class="badge badge-tool">Docker</span></div>
            <div class="stage-time">~7 min</div>
            <div class="chevron @(IsStageOpen("s3") ? "chevron-open" : "")">›</div>
        </div>
        @if (IsStageOpen("s3"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">3.1</div>
                    <div class="step-info">
                        <div class="step-title">Multi-stage Docker Build <span class="badge badge-tool">Container</span></div>
                        <div class="step-desc">Builds a secure .NET 10 image using non-root users and minimal runtime base.</div>
                        <div class="file-block"><span class="cmd-comment"># Secure Dockerfile sample</span>
FROM mcr.microsoft.com/dotnet/aspnet:10.0
USER appuser
COPY --from=build /app/publish .</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s4")'>
            <div class="stage-dot dot-purple"></div>
            <div class="stage-name">Stage 4 · Infrastructure & Cluster <span class="badge badge-iac">Terraform</span></div>
            <div class="stage-time">~10 min</div>
            <div class="chevron @(IsStageOpen("s4") ? "chevron-open" : "")">›</div>
        </div>
        @if (IsStageOpen("s4"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">4.1</div>
                    <div class="step-info">
                        <div class="step-title">k3d Local Cluster Setup <span class="badge badge-local">Local</span></div>
                        <div class="step-desc">Replaces AKS by spinning up a full Kubernetes cluster inside Docker.</div>
                        <div class="cmd-block">k3d cluster create demo-cluster --agents 1</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s5")'>
            <div class="stage-dot dot-coral"></div>
            <div class="stage-name">Stage 5 · Progressive Delivery <span class="badge badge-tool">Argo Rollouts</span></div>
            <div class="stage-time">~12 min</div>
            <div class="chevron @(IsStageOpen("s5") ? "chevron-open" : "")">›</div>
        </div>
        @if (IsStageOpen("s5"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">5.1</div>
                    <div class="step-info">
                        <div class="step-title">Canary Strategy (10% → 100%) <span class="badge badge-tool">GitOps</span></div>
                        <div class="step-desc">Shifts traffic to the new version while monitoring Prometheus metrics.</div>
                        <div class="cmd-block">kubectl argo rollouts promote demo-app</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="stage">
        <div class="stage-header" @onclick='() => ToggleStage("s6")'>
            <div class="stage-dot dot-green"></div>
            <div class="stage-name">Stage 6 · Observability <span class="badge badge-obs">Prometheus</span></div>
            <div class="stage-time">~5 min</div>
            <div class="chevron @(IsStageOpen("s6") ? "chevron-open" : "")">›</div>
        </div>
        @if (IsStageOpen("s6"))
        {
            <div class="stage-body">
                <div class="step">
                    <div class="step-num">6.1</div>
                    <div class="step-info">
                        <div class="step-title">Metrics & Dashboards <span class="badge badge-tool">Grafana</span></div>
                        <div class="step-desc">Visualize cluster health and application performance in real-time.</div>
                    </div>
                </div>
            </div>
        }
    </div>

</div>

@code {
    // Stores the ID of stages that are currently expanded
    private HashSet<string> openStages = new() { "s1" };

    // Toggles the visibility of a pipeline stage
    private void ToggleStage(string id)
    {
        if (!openStages.Add(id))
        {
            openStages.Remove(id);
        }
    }

    // Checks if a specific stage should be rendered as open
    private bool IsStageOpen(string id) => openStages.Contains(id);
}