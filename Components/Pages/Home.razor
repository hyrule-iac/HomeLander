@page "/"
@using System.ServiceModel.Syndication
@using System.Xml
@using Microsoft.Extensions.Caching.Memory
@inject IMemoryCache Cache
@implements IDisposable

<div class="home-container">
    <header class="hero">
        <div class="hero-content">
            <span class="badge-live">LIVE COMMAND CENTER</span>
            <h1>Hyrule-Nexus Intelligence</h1>
            <p>Cloud Security & Geek Culture Monitoring</p>
        </div>
    </header>

    <div class="dashboard-grid">
        <section class="feed-section">
            <h2 class="section-title"><span class="icon">📰</span> Main Intel Stream</h2>
            @if (IsLoading)
            {
                <div class="loading-state">Sincronizando feeds...</div>
            }
            else
            {
                @foreach (var news in NewsItems)
                {
                    <article class="news-card @news.Category.ToLower()">
                        <div class="card-horizontal">
                            <div class="card-img-container">
                                @if (!string.IsNullOrEmpty(news.ImageUrl))
                                {
                                    <img src="@news.ImageUrl" alt="intel" />
                                }
                            </div>
                            <div class="card-content">
                                <div class="card-tag">@news.Category</div>
                                <span class="timestamp">@news.PublishDate.ToString("HH:mm")</span>
                                <h3>@news.Title</h3>
                                <p>@news.Summary</p>
                                <div class="card-footer">
                                    <span class="source">@news.Source</span>
                                    <a href="@news.Link" target="_blank" class="read-more">Analyze →</a>
                                </div>
                            </div>
                        </div>
                    </article>
                }
            }
        </section>

        <aside class="sidebar-feed">
            <div class="side-block cve-tracker">
                <h3><span class="icon">🛡️</span> Live CVE Alerts</h3>
                @foreach (var cve in CveItems)
                {
                    <div class="cve-item high">
                        <span class="cve-id">ALERT</span>
                        <p><strong>@cve.Title</strong></p>
                        <a href="@cve.Link" target="_blank" class="mini-link">Details</a>
                    </div>
                }
            </div>

            <div class="side-block geek-box">
                <h3><span class="icon">🍿</span> Geek Pulse Live</h3>
                @foreach (var geek in GeekItems)
                {
                    <div class="geek-pulse-item">
                        <p>@geek.Title</p>
                        <a href="@geek.Link" target="_blank" class="mini-link">View Intel</a>
                    </div>
                }
            </div>
        </aside>
    </div>
</div>

@code {
    private List<NewsItem> NewsItems = new();
    private List<NewsItem> CveItems = new();
    private List<NewsItem> GeekItems = new();
    private bool IsLoading = true;
    private System.Threading.Timer? _timer;

    public class NewsItem
    {
        public string Title { get; set; } = "";
        public string Summary { get; set; } = "";
        public string Link { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string Source { get; set; } = "";
        public string Category { get; set; } = "";
        public DateTime PublishDate { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAllFeeds();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(async () => { await LoadAllFeeds(); StateHasChanged(); }), null, TimeSpan.FromMinutes(10), TimeSpan.FromMinutes(10));
    }

    private async Task LoadAllFeeds()
    {
        IsLoading = true;

        var feedSources = new List<(string Url, string Category, int Count)>
    {
        // 🔒 Ciberseguridad
        ("https://www.cisa.gov/cybersecurity-advisories/all.xml",         "Security", 2),
        ("https://feeds.feedburner.com/TheHackersNews",                   "Security", 2),
        ("https://krebsonsecurity.com/feed/",                             "Security", 1),

        // ☁️ Cloud / DevOps
        ("https://aws.amazon.com/blogs/aws/feed/",                        "Cloud",    2),
        ("https://azure.microsoft.com/en-us/blog/feed/",                  "Cloud",    2),
        ("https://cloud.google.com/feeds/gcp-release-notes.xml",          "Cloud",    1),

        // 💻 Tech General
        ("https://www.theverge.com/rss/index.xml",                        "General",  2),
        ("https://feeds.arstechnica.com/arstechnica/index",               "General",  2),
        ("https://www.wired.com/feed/rss",                                "General",  1),

        // 🤖 IA / ML
        ("https://openai.com/news/rss.xml",                               "AI",       2),
        ("https://huggingface.co/blog/feed.xml",                          "AI",       2),
        ("https://blogs.microsoft.com/ai/feed/",                          "AI",       1),

        // 🍿 Geek / Cultura pop
        ("https://boundingintocomics.com/feed/",                          "Geek",     2),
        ("https://www.cbr.com/feed/",                                     "Geek",     2),

        // 🎌 Anime
        ("https://www.animenewsnetwork.com/all/rss.xml?ann-edition=us",   "Anime",    2),
        ("https://myanimelist.net/rss/news.xml",                          "Anime",    2),
    };

        // CVE sidebar (se mantiene separado)
        CveItems = await FetchFeed(
            "https://www.cisa.gov/cybersecurity-advisories/all.xml", "Security", 3);

        // Geek sidebar
        GeekItems = await FetchFeed(
            "https://boundingintocomics.com/feed/", "Geek", 3);

        // Main stream: fetch todas las fuentes en paralelo
        var tasks = feedSources.Select(f => FetchFeed(f.Url, f.Category, f.Count));
        var results = await Task.WhenAll(tasks);

        NewsItems = results
            .SelectMany(x => x)
            .OrderByDescending(x => x.PublishDate)  // Más recientes primero
            .ToList();

        IsLoading = false;
    }

    private async Task<List<NewsItem>> FetchFeed(string url, string category, int count)
    {
        try
        {
            using var reader = XmlReader.Create(url);
            var feed = SyndicationFeed.Load(reader);
            return feed.Items.Take(count).Select(item => new NewsItem
            {
                Title = item.Title.Text,
                Summary = Truncate(StripHtml(item.Summary?.Text ?? ""), 120),
                Link = item.Links.FirstOrDefault()?.Uri.ToString() ?? "",
                PublishDate = item.PublishDate.DateTime,
                Category = category,
                Source = feed.Title.Text,
                ImageUrl = ExtractImageUrl(item, item.Links.FirstOrDefault()?.Uri.ToString() ?? "")
            }).ToList();
        }
        catch { return new List<NewsItem>(); }
    }

    private string ExtractImageUrl(SyndicationItem item, string articleLink = "")
    {
        string? url = null;

        // 1. Enclosure (podcast/old RSS standard)
        url = item.Links.FirstOrDefault(l => l.RelationshipType == "enclosure")?.Uri.ToString();

        // 2. Media RSS (Yahoo standard) - fix del namespace
        if (string.IsNullOrEmpty(url))
        {
            var mediaContent = item.ElementExtensions
                .FirstOrDefault(e => e.OuterName == "content" &&
                                e.OuterNamespace == "http://search.yahoo.com/mrss/");
        
            if (mediaContent != null)
                url = mediaContent.GetObject<System.Xml.XmlElement>().GetAttribute("url");
        }

        // 3. media:thumbnail (alternativa común)
        if (string.IsNullOrEmpty(url))
        {
            var mediaThumbnail = item.ElementExtensions
                .FirstOrDefault(e => e.OuterName == "thumbnail" &&
                                e.OuterNamespace == "http://search.yahoo.com/mrss/");
        
            if (mediaThumbnail != null)
                url = mediaThumbnail.GetObject<System.Xml.XmlElement>().GetAttribute("url");
        }

        // 4. <img> dentro del Summary HTML
        if (string.IsNullOrEmpty(url))
        {
            string content = item.Summary?.Text ?? "";
            var match = System.Text.RegularExpressions.Regex.Match(
                content, @"<img[^>]+src=[""']([^""']+)[""']");
            if (match.Success) url = match.Groups[1].Value;
        }

        // 5. Fallback: favicon del sitio de origen ✅
        if (string.IsNullOrEmpty(url) && !string.IsNullOrEmpty(articleLink))
        {
            try
            {
                var domain = new Uri(articleLink).Host;
                url = $"https://www.google.com/s2/favicons?domain={domain}&sz=128";
            }
            catch { }
        }

        return url ?? "https://via.placeholder.com/400x200/161616/03dac6?text=NEXUS+INTEL";
    }

    private static string StripHtml(string input)
    {
        if (string.IsNullOrEmpty(input)) return string.Empty;
        // Remove tags
        var noTags = System.Text.RegularExpressions.Regex.Replace(input, "<.*?>", string.Empty);
        // Decode HTML entities (use fully-qualified name to avoid needing an extra using)
        return System.Net.WebUtility.HtmlDecode(noTags).Trim();
    }

    private static string Truncate(string input, int maxLength)
    {
        if (string.IsNullOrEmpty(input)) return string.Empty;
        if (maxLength <= 0) return string.Empty;
        if (input.Length <= maxLength) return input;
        // Reserve room for ellipsis
        const string ellipsis = "…";
        var allowed = Math.Max(0, maxLength - ellipsis.Length);
        return input.Substring(0, allowed).TrimEnd() + ellipsis;
    }

    // Implement IDisposable to satisfy the interface declared with @implements IDisposable.
    public void Dispose()
    {
        _timer?.Dispose();
        _timer = null;
    }
}