@page "/kleva-devops"
@rendermode InteractiveServer

<div class="container">
    <div class="header">
        <h1>Presentation guide — kleva-devops-lab</h1>
        <p>@Topics.Count sections · ~45 min · Full stack · Hiring manager perspective</p>
    </div>

    <div class="controls">
        <button class="ctrl-btn" @onclick="() => ToggleAll(true)">Expand all</button>
        <button class="ctrl-btn" @onclick="() => ToggleAll(false)">Collapse all</button>
    </div>

    @foreach (var topic in Topics)
    {
        <div class="phase">
            <div class="phase-header" @onclick="() => TogglePhase(topic.Id)">
                <div class="phase-num" style="background:@topic.ColorHex; color:@topic.TextColorHex;">@topic.Id</div>
                <span class="phase-icon">@topic.Icon</span>
                <span class="phase-title">@topic.Title</span>
                <span class="phase-time">@topic.Duration</span>
                <span class="phase-arrow @(IsPhaseOpen(topic.Id) ? "open" : "")">▶</span>
            </div>

            <div class="phase-body @(IsPhaseOpen(topic.Id) ? "open" : "")">
                <div class="chips">
                    @foreach (var chip in topic.Chips)
                    {
                        <span class="chip @chip.CssClass">@chip.Label</span>
                    }
                </div>

                <div class="section-label">Talking Points & Workflow</div>
                <div class="points-list">
                    @foreach (var point in topic.Points)
                    {
                        <div class="point-item">
                            <span class="point-marker">▹</span>
                            <div class="point-content">@((MarkupString)point)</div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(topic.Warning))
                {
                    <div class="warning-box">
                        <strong>⚠️ Note:</strong> @((MarkupString)topic.Warning)
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private Dictionary<int, bool> phaseStates = new();

    public class Topic
    {
        public int Id { get; set; }
        public string Title { get; set; }
        public string Icon { get; set; }
        public string Duration { get; set; }
        public string ColorHex { get; set; }
        public string TextColorHex { get; set; } = "#ffffff";
        public List<ChipModel> Chips { get; set; } = new();
        public List<string> Points { get; set; } = new();
        public string Warning { get; set; }
    }

    public class ChipModel
    {
        public string Label { get; set; }
        public string CssClass { get; set; }
    }

    private List<Topic> Topics = new();

    protected override void OnInitialized()
    {
        Topics = new List<Topic>
        {
            // ... (Tus temas anteriores se mantienen igual aquí)
            
            new Topic {
                Id = 7,
                Title = "Local Manual Execution (PowerShell)",
                Icon = "💻",
                Duration = "Live Demo",
                ColorHex = "#3B6D11",
                Chips = new List<ChipModel> {
                    new ChipModel { Label = "Windows 11", CssClass = "gray" },
                    new ChipModel { Label = "k3d", CssClass = "blue" },
                    new ChipModel { Label = "Argo", CssClass = "coral" }
                },
                Points = new List<string> {
                    "<strong>1. Cluster Provisioning:</strong> <pre>k3d cluster create kleva-cluster --port '8080:80@loadbalancer'</pre>",
                    "<strong>2. Authentication:</strong> Create the GHCR secret to pull private images: <pre>kubectl create ns app; kubectl create secret docker-registry ghcr-secret --docker-server=ghcr.io --docker-username='USER' --docker-password='TOKEN' --namespace=app</pre>",
                    "<strong>3. Deployment:</strong> Apply manifests in order: <pre>kubectl apply -f k8s/application/app-config.yaml; kubectl apply -f k8s/application/app-rollout.yaml</pre>",
                    "<strong>4. Live Monitoring:</strong> Watch the Canary shift in real-time: <pre>kubectl argo rollouts get rollout kleva-dotnet -n app --watch</pre>",
                    "<strong>5. Trigger Update:</strong> Force a new version to demonstrate the strategy: <pre>kubectl argo rollouts set image kleva-dotnet kleva-dotnet=ghcr.io/hyrule-iac/kleva-app:latest -n app</pre>"
                },
                Warning = "Verify that <strong>Docker Desktop</strong> is running and your PowerShell session has Administrator privileges before starting the cluster."
            }
        };

        foreach (var t in Topics) phaseStates[t.Id] = false;
    }

    private void TogglePhase(int id) => phaseStates[id] = !phaseStates.GetValueOrDefault(id);
    private bool IsPhaseOpen(int id) => phaseStates.GetValueOrDefault(id);
    private void ToggleAll(bool open) { foreach (var key in Topics.Select(t => t.Id)) phaseStates[key] = open; }
}